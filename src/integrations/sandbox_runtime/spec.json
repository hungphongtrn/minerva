{
  "version": "1.0.0",
  "gateway": {
    "port": 18790,
    "health_path": "/health",
    "execute_path": "/webhook",
    "stream_mode": "none"
  },
  "auth": {
    "mode": "bearer"
  },
  "runtime": {
    "config_path": "/workspace/.minerva/config.json",
    "start_command": "minerva-gateway --config /workspace/.minerva/config.json"
  },
  "examples": {
    "execute_request": {
      "message": "Hello, Minerva!",
      "context": {
        "session_id": "session-123",
        "sender_id": "user-456"
      }
    },
    "execute_response": {
      "success": true,
      "output": {
        "message": "Response from sandbox runtime",
        "timestamp": "2026-03-05T00:00:00Z"
      }
    }
  }
}
