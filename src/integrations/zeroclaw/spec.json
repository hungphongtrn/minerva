{
  "version": "1.0.0",
  "gateway": {
    "port": 18790,
    "health_path": "/health",
    "execute_path": "/webhook",
    "stream_mode": "none"
  },
  "auth": {
    "mode": "bearer"
  },
  "runtime": {
    "config_path": "/workspace/.zeroclaw/config.json",
    "start_command": "zeroclaw-gateway --config /workspace/.zeroclaw/config.json"
  },
  "daytona": {
    "snapshot_name": "picoclaw-base",
    "target_region": "eu",
    "base_image": "daytonaio/workspace-picoclaw:latest"
  },
  "examples": {
    "execute_request": {
      "message": "Hello, Zeroclaw!",
      "context": {
        "session_id": "session-123",
        "sender_id": "user-456"
      }
    },
    "execute_response": {
      "success": true,
      "output": {
        "message": "Response from Zeroclaw",
        "timestamp": "2026-03-05T00:00:00Z"
      }
    }
  }
}
