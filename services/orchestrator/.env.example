PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Daytona Configuration
DAYTONA_SERVER_URL=
DAYTONA_API_KEY=
DAYTONA_TARGET=

# Model Provider Configuration (NEW - replaces LLM_* variables)
# Choose your model provider: 'openai' or 'anthropic'
MODEL_PROVIDER=openai

# Provider API Keys (only need the one matching MODEL_PROVIDER)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Model Configuration (optional - defaults are provided)
# OpenAI default: gpt-4-turbo-preview
# Anthropic default: claude-3-opus-20240229
MODEL_NAME=

# Generation parameters (optional)
MODEL_TEMPERATURE=0.7
MODEL_MAX_TOKENS=4096

# DEPRECATED: Legacy LLM Configuration
# The old LLM_* variables are deprecated and will be removed in a future version.
# Please migrate to the new MODEL_PROVIDER configuration above.
# LLM_BASE_URL=
# LLM_API_KEY=
# LLM_MODEL=
